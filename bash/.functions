#!/bin/bash

function mkcd {
    mkdir -p "$1" && cd "$1"
}

function ffss {
	ffsubsync "$1" -i "$2" -o "$3"
}

function video2gif {
    if [ -z "$1" ]; then
        echo "Usage: video2gif filename.mp4"
        return 1
    fi

    local input="$1"
    local output="${input%.*}.gif"
    local palette="/tmp/palette.png"

    echo "Converting $input to $output..."

    ffmpeg -v warning -i "$input" -vf "fps=15,scale=720:-1:flags=lanczos,palettegen" -y "$palette"
    ffmpeg -v warning -i "$input" -i "$palette" -filter_complex "fps=15,scale=720:-1:flags=lanczos[x];[x][1:v]paletteuse" "$output"

    rm "$palette"

    echo "Done! Created: $output"
}

git-open() {
    if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
        return 1
    fi

    local url=$(git config --get remote.origin.url)

    if [ -z "$url" ]; then
        return 1
    fi

    if [[ $url =~ ^git@ ]]; then
        url=$(echo "$url" | sed -e 's/:/\//' -e 's/git@/https:\/\//' -e 's/\.git$//')
    elif [[ $url =~ \.git$ ]]; then
        url=$(echo "$url" | sed 's/\.git$//')
    fi

    echo "Open: $url"

    if command -v xdg-open > /dev/null; then
        xdg-open "$url"
    else
        return 1
    fi
}
