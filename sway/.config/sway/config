# Power Menu

bindsym $mod+Shift+e exec swaynag -t default -m "Power Menu" -b "Lock" "bash -c '$screenlock'" -b "Suspend" "systemctl suspend" -b "Hibernate" "systemctl hibernate" -b "Reboot" "systemctl reboot" -b "Poweroff" "systemctl poweroff" -b "Exit" "swaymsg exit"

# Auto start

seat * xcursor_theme ComixCursors-Slim-Black 20

exec_always {
    # Theme
    gsettings set org.gnome.desktop.interface font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface document-font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    gsettings set org.gnome.desktop.interface gtk-theme "Adwaita-dark"
    gsettings set org.gnome.desktop.wm.preferences theme "Adwaita-dark"
    gsettings set org.gnome.desktop.interface icon-theme "AdwaitaLegacy"
    gsettings set org.gnome.desktop.interface cursor-theme "ComixCursors-Slim-Black"
    gsettings set org.gnome.desktop.interface cursor-size 20
}

exec {
	# Environments
    dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP GTK_THEME XCURSOR_SIZE XCURSOR_THEME SWAYSOCK I3SOCK

    # Notification daemon
    rm -f $wobsock && mkfifo $wobsock && tail -f $wobsock | wob
	mako
	
	# Power alert daemon
	poweralertd -sS
	
    # KDE Connect daemon
	kdeconnectd
	
	# Clipboard manager daemon
	wl-paste --type text --watch cliphist store
	wl-paste --type image --watch cliphist store
	
	# Gamma manager daemon
	wlsunset -l 37.77426 -L 29.0876
	
	# Network manager daemon
	nm-applet --indicator
}

include /etc/sway/config-vars.d/*
