# Variables

set {
    $mod Mod4

    $bg_color "#225877"
    $wallpaper "$HOME/.dotfiles/.wallpaper.jpg"

    $language "tr"
    $keyboard "1:1:AT_Translated_Set_2_keyboard"
    $touchpad "1739:52967:SYNA32E4:00_06CB:CEE7_Touchpad"

    # Tools
    $terminal foot
    $file-manager pcmanfm
    $web-browser librewolf
    $radio radiotray-ng
    $menu wmenu-run -b -i -f "Iosevka 10"
    $zooming-tool wooz --invert-scroll --mouse-track
    $colorpicker hyprpicker -ard && notify-send $(wl-paste)
    $clipboard cliphist list | wmenu -b -l 10 -i -f "Iosevka 10" | cliphist decode | wl-copy

    $wobsock $XDG_RUNTIME_DIR/wob.sock
}

# Output & Input configuration

font pango:Iosevka 10

output {
    # "eDP-1" bg $bg_color solid_color
    # "eDP-2" bg $bg_color solid_color
    "eDP-1" background $wallpaper fill
    "eDP-2" background $wallpaper fill
}

input $keyboard {
    xkb_layout $language
    xkb_numlock enabled
}

input $touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    scroll_method two_finger
}

# Container configurations

gaps inner 10
default_border pixel 2

# Status bar

bar {
    position top
    swaybar_command waybar
}

# Moving around

bindsym {
    $mod+Left focus left
    $mod+Down focus down
    $mod+Up focus up
    $mod+Right focus right

    $mod+Shift+Left move left
    $mod+Shift+Down move down
    $mod+Shift+Up move up
    $mod+Shift+Right move right
}

# Resizing containers

bindsym $mod+r mode "resize"

mode "resize" {
    bindsym {
        Return mode "default"
        Escape mode "default"

        Right resize shrink width 10px
        Up resize grow height 10px
        Down resize shrink height 10px
        Left resize grow width 10px
    }
}

# Layout stuff

popup_during_fullscreen smart

bindsym {
    $mod+b splith
    $mod+v splitv
    $mod+t layout tabbed
    $mod+s layout stacking
    $mod+e layout toggle split

    $mod+f fullscreen
    $mod+a focus parent
    $mod+space focus mode_toggle
    $mod+Shift+space floating toggle
}

for_window {
    [class="vesktop"] floating enable, move position center

    [instance="Minecraft*"] floating enable, move position center

    [title="About*"] floating enable, move position center
    [title="about*"] floating enable, move position center
    [title="Hakkında*"] floating enable, move position center
    [title="hakkında*"] floating enable, move position center
    [title="OCR Result"] floating enable, move position center

    [app_id="pcmanfm"] floating enable, move position center
    [app_id="xarchiver"] floating enable, move position center
    [app_id="pavucontrol"] floating enable, move position center
    [app_id="CachyOSHello"] floating enable, move position center
    [app_id="nm-connection-*"] floating enable, move position center
    [app_id="org.cachyos.cachyos-pi"] floating enable, move position center
    [app_id="org.keepassxc.KeePassXC"] floating enable, move position center
    [app_id="org.cachyos.KernelManager"] floating enable, move position center
    [app_id="io.github.quodlibet.QuodLibet"] floating enable, move position center
}

for_window [floating] title_format "[F] %title"
for_window [shell="xwayland"] title_format "[XWayland] %title"

# Workspaces

set $w workspace
set $c container

bindsym {
    Control+Left $w prev
    Control+Right $w next

    $mod+1 $w number 1
    $mod+2 $w number 2
    $mod+3 $w number 3
    $mod+4 $w number 4
    $mod+5 $w number 5
    $mod+6 $w number 6
    $mod+7 $w number 7
    $mod+8 $w number 8
    $mod+9 $w number 9
    $mod+0 $w number 10

    $mod+Shift+1 move $c to $w number 1
    $mod+Shift+2 move $c to $w number 2
    $mod+Shift+3 move $c to $w number 3
    $mod+Shift+4 move $c to $w number 4
    $mod+Shift+5 move $c to $w number 5
    $mod+Shift+6 move $c to $w number 6
    $mod+Shift+7 move $c to $w number 7
    $mod+Shift+8 move $c to $w number 8
    $mod+Shift+9 move $c to $w number 9
    $mod+Shift+0 move $c to $w number 10
}

# Scratchpad

bindsym {
    $mod+minus scratchpad show
    $mod+Shift+minus move scratchpad
}

# Shortcuts

floating_modifier $mod normal

bindsym {
    # TODO: XF86Launch2 exec
	
	# Window actions
    $mod+q kill
    $mod+Shift+r reload

    # Tool keybinds
    $mod+Return exec $terminal
    $mod+i exec $file-manager
    $mod+w exec $web-browser
    $mod+1+r exec $radio
    $mod+m exec $menu
    $mod+z exec $zooming-tool
    $mod+p exec $colorpicker
    $mod+c exec $clipboard
    $mod+Shift+c exec cliphist wipe
    $mod+o exec bash /home/$USER/.dotfiles/scripts/ocr.sh

    # Backlight Control
    XF86MonBrightnessUp exec brightnessctl set +1% -m | cut -d, -f4 | tr -d '%' > $wobsock
    XF86MonBrightnessDown exec brightnessctl set 1%- -m | cut -d, -f4 | tr -d '%' > $wobsock

    # Sound Control
    XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}' > $wobsock
    XF86AudioRaiseVolume exec wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 1%+ && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}' > $wobsock

    # Screenshot
    Shift+Print exec grimshot copy output && notify-send -i edit-copy "Screenshot" "Full screen copied to clipboard"
    Shift+Alt+Print exec grimshot copy active && notify-send -i edit-copy "Screenshot" "Active window copied to clipboard"
    Shift+Control+Print exec grimshot copy area && notify-send -i edit-copy "Screenshot" "Selected area copied to clipboard"
    Print exec grimshot save output $HOME/screenshots/$(date +"%Y-%m-%d-%I-%M-%S-%p").png && notify-send -i camera-photo "Screenshot" "Full screen saved to folder"
    Alt+Print exec grimshot save active $HOME/screenshots/$(date +"%Y-%m-%d-%I-%M-%S-%p").png && notify-send -i camera-photo "Screenshot" "Active window saved to folder"
    Control+Print exec grimshot save area $HOME/screenshots/$(date +"%Y-%m-%d-%I-%M-%S-%p").png && notify-send -i camera-photo "Screenshot" "Selected area saved to folder"
}

