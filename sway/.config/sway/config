# Variables

set {
    $mod Mod4

    $bg_color "#000000"
    $wallpaper "$HOME/.dotfiles/wallpapers/felsenriff-am-meeresstrand.jpg"

    $language "tr"
    $keyboard "1:1:AT_Translated_Set_2_keyboard"
    $touchpad "1739:52967:SYNA32E4:00_06CB:CEE7_Touchpad"

    # Tools
    $terminal foot
    $file-manager pcmanfm
    $web-browser librewolf
    $radio radiotray-ng
    $zoom wooz --invert-scroll --mouse-track
    $color-picker hyprpicker --autocopy --notify --render-inactive --disable-preview
    $menu wmenu-run -b -i -f "Iosevka 10" -N 1c1c1c -n e0e0e0 -M 1c1c1c -m e0e0e0 -S 4a7bb0 -s 000000
    $clipboard cliphist list | wmenu -b -l 10 -i -f "Iosevka 10" -N 1c1c1c -n e0e0e0 -M 1c1c1c -m e0e0e0 -S 4a7bb0 -s 000000 | cliphist decode | wl-copy

    $wobsock $XDG_RUNTIME_DIR/wob.sock
}

# Output & Input configuration

output {
    # "eDP-1" bg $bg_color solid_color
    # "eDP-2" bg $bg_color solid_color
    "eDP-1" background $wallpaper fill
    "eDP-2" background $wallpaper fill
}

input $keyboard {
    xkb_layout $language
    xkb_numlock enabled
}

input $touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    scroll_method two_finger
}

# Container configurations

font pango:Iosevka 8

gaps inner 8
default_border pixel 2

set {
    $black   #000000
    $base    #111111
    $surface #1c1c1c
    $text    #529961
    $red     #cc4444
    $blue    #4a7bb0
}

client.background        $black   $base    $black $black   $black
client.focused           $blue    $surface $blue  $blue    $surface
client.focused_inactive  $surface $base    $blue  $surface $base
client.focused_tab_title $surface $base    $blue  $surface $base
client.unfocused         $surface $base    $blue  $surface $base
client.urgent            $red     $black   $blue  $red     $black
client.placeholder       $black   $base    $blue  $black   $base

# Status bar

bar {
    position top
    swaybar_command waybar
}

# Moving around

bindsym {
    $mod+Left focus left
    $mod+Down focus down
    $mod+Up focus up
    $mod+Right focus right

    $mod+Shift+Left move left
    $mod+Shift+Down move down
    $mod+Shift+Up move up
    $mod+Shift+Right move right
}

# Resizing containers

bindsym $mod+r mode "Resize"

mode "Resize" {
    bindsym {
        Return mode "default"
        Escape mode "default"

        Right resize shrink width 10px
        Up resize grow height 10px
        Down resize shrink height 10px
        Left resize grow width 10px
    }
}

# Layout stuff

popup_during_fullscreen smart

bindsym {
    $mod+b splith
    $mod+v splitv
    $mod+t layout tabbed
    $mod+s layout stacking
    $mod+e layout toggle split

    $mod+f fullscreen
    $mod+a focus parent
    $mod+space focus mode_toggle
    $mod+Shift+space floating toggle
}

for_window [shell="xwayland"] title_format "[XWayland] %title"

for_window {
    [title="About*"] floating enable, move position center
    [title="about*"] floating enable, move position center
    [title="Hakkında*"] floating enable, move position center
    [title="hakkında*"] floating enable, move position center
    [title="OCR Result"] floating enable, move position center

    [app_id="7zFM"] floating enable, move position center
    [app_id="pcmanfm"] floating enable, move position center
    [app_id="xarchiver"] floating enable, move position center
    [app_id="pavucontrol"] floating enable, move position center
    [app_id="nm-connection-*"] floating enable, move position center
    [app_id="org.cachyos.hello"] floating enable, move position center
    [app_id="cute-sway-recorder"] floating enable, move position center
    [app_id="org.cachyos.cachyos-pi"] floating enable, move position center
    [app_id="org.cachyos.scx-manager"] floating enable, move position center
    [app_id="org.keepassxc.KeePassXC"] floating enable, move position center
    [app_id="org.cachyos.KernelManager"] floating enable, move position center
    [app_id="io.github.quodlibet.QuodLibet"] floating enable, move position center
}

# Workspaces

set $w workspace
set $c container

bindsym {
    Control+Left $w prev
    Control+Right $w next

    $mod+1 $w number 1
    $mod+2 $w number 2
    $mod+3 $w number 3
    $mod+4 $w number 4
    $mod+5 $w number 5
    $mod+6 $w number 6
    $mod+7 $w number 7
    $mod+8 $w number 8
    $mod+9 $w number 9
    $mod+0 $w number 10

    $mod+Shift+1 move $c to $w number 1
    $mod+Shift+2 move $c to $w number 2
    $mod+Shift+3 move $c to $w number 3
    $mod+Shift+4 move $c to $w number 4
    $mod+Shift+5 move $c to $w number 5
    $mod+Shift+6 move $c to $w number 6
    $mod+Shift+7 move $c to $w number 7
    $mod+Shift+8 move $c to $w number 8
    $mod+Shift+9 move $c to $w number 9
    $mod+Shift+0 move $c to $w number 10
}

# Scratchpad

bindsym {
    $mod+minus scratchpad show
    $mod+Shift+minus move scratchpad
}

# Shortcuts

floating_modifier $mod normal

bindsym {
	# Window actions
    $mod+q kill
    $mod+Shift+r reload

    # Tool keybinds
    $mod+Return exec $terminal
    $mod+i exec $file-manager
    $mod+w exec $web-browser
    $mod+1+r exec $radio
    $mod+z exec $zoom
    $mod+p exec $color-picker
    $mod+m exec $menu
    $mod+c exec $clipboard
    $mod+Shift+c exec cliphist wipe
    $mod+o exec bash /home/$USER/.dotfiles/scripts/ocr.sh

    # Backlight Control
    XF86MonBrightnessUp exec brightnessctl set +1% | grep -oP '\(\K[^%]+' > $wobsock
    XF86MonBrightnessDown exec brightnessctl set 1%- | grep -oP '\(\K[^%]+' > $wobsock

    # Sound Control
    XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}' > $wobsock
    XF86AudioRaiseVolume exec wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 1%+ && wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}' > $wobsock

    # Screenshot
    Shift+Print exec grimshot copy output && notify-send -i edit-copy "Screenshot" "Full screen copied to clipboard"
    Shift+Alt+Print exec grimshot copy active && notify-send -i edit-copy "Screenshot" "Active window copied to clipboard"
    Shift+Control+Print exec grimshot copy area && notify-send -i edit-copy "Screenshot" "Selected area copied to clipboard"
    Print exec grimshot save output $HOME/screenshots/$(date +"%Y%m%d-%H%M%S").png && notify-send "Screenshot" "Full screen saved to folder"
    Alt+Print exec grimshot save active $HOME/screenshots/$(date +"%Y%m%d-%H%M%S").png && notify-send "Screenshot" "Active window saved to folder"
    Control+Print exec grimshot save area $HOME/screenshots/$(date +"%Y%m%d-%H%M%S").png && notify-send "Screenshot" "Selected area saved to folder"
}

# Idle manager

set $screenlock grim /tmp/screenshot.png && ffmpeg -i /tmp/screenshot.png -vf "gblur=sigma=2" -frames:v 1 -y /tmp/lock-image.png && swaylock -f -i /tmp/lock-image.png

# bindsym XF86Launch2 exec bash -c "$screenlock"
# exec swayidle -w timeout 300 '$screenlock' timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' before-sleep 'swaylock -f -c 000000'

# Power menu

bindsym $mod+Shift+e exec swaynag -t default -m "Power Menu" -b "Lock" "bash -c '$screenlock'" -b "Suspend" "systemctl suspend" -b "Hibernate" "systemctl hibernate" -b "Reboot" "systemctl reboot" -b "Poweroff" "systemctl poweroff" -b "Exit" "swaymsg exit"

# Auto start

seat * xcursor_theme ComixCursors-Slim-Black 20

exec_always {
    # Theme
    gsettings set org.gnome.desktop.interface font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface document-font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"
    gsettings set org.gnome.desktop.wm.preferences theme "Adwaita"
    gsettings set org.gnome.desktop.interface icon-theme "Adwaita"
    gsettings set org.gnome.desktop.interface cursor-theme "ComixCursors-Slim-Black"
    gsettings set org.gnome.desktop.interface cursor-size 20
}

exec {
	# Environments
    dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP GTK_THEME XCURSOR_SIZE XCURSOR_THEME SWAYSOCK I3SOCK

    # Notification daemon
    rm -f $wobsock && mkfifo $wobsock && tail -f $wobsock | wob
	mako

    # KDE Connect daemon
	kdeconnectd

	# Clipboard manager daemon
	wl-paste --type text --watch cliphist store
	wl-paste --type image --watch cliphist store

	# Gamma manager daemon
	wlsunset -S 19:30 -s 06:00 -t 4000 -T 6500

	# Network manager daemon
	nm-applet --indicator
}

