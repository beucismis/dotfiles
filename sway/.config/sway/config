# Variables

set {
    $mod Mod4

    $bg-color "#4a7bb0"
    $wallpaper "$HOME/.dotfiles/wallpapers/felsenriff-am-meeresstrand.jpg"

    $language "tr"
    $keyboard "1:1:AT_Translated_Set_2_keyboard"
    $touchpad "1739:52967:SYNA32E4:00_06CB:CEE7_Touchpad"

    # Tools
    $terminal foot
    $file-manager pcmanfm
    $web-browser librewolf
    $screen-magnifier wooz --invert-scroll --mouse-track
    $screen-ocr bash /home/$USER/.dotfiles/scripts/ocr.sh
    $color-picker hyprpicker --autocopy --notify --render-inactive --disable-preview
    $application-menu wmenu-run \
        -bi -f "Iosevka 10" -N 111111 -n e0e0e0 -M 111111 -m e0e0e0 -S 4a7bb0 -s 000000
    $clipboard-menu cliphist list | wmenu \
        -bi -l 15 -f "Iosevka 10" -N 111111 -n e0e0e0 -M 111111 -m e0e0e0 -S 4a7bb0 -s 000000 \
        | cliphist decode | wl-copy
}

# Output & Input configuration

output {
    # "eDP-1" bg $bg-color solid_color
    # "eDP-2" bg $bg-color solid_color
    # "eDP-1" background $wallpaper fill
    "eDP-2" background $wallpaper fill
}

input $keyboard {
    xkb_layout $language
    xkb_numlock enabled
}

input $touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    scroll_method two_finger
}

# Container configurations

font pango:Iosevka 8

gaps inner 8
default_border pixel 2

set {
    $black   #000000
    $base    #111111
    $surface #1c1c1c
    $text    #529961
    $red     #cc4444
    $blue    #4a7bb0
}

client.background        $black   $base    $black $black   $black
client.focused           $blue    $surface $blue  $blue    $surface
client.focused_inactive  $surface $base    $blue  $surface $base
client.focused_tab_title $surface $base    $blue  $surface $base
client.unfocused         $surface $base    $blue  $surface $base
client.urgent            $red     $black   $blue  $red     $black
client.placeholder       $black   $base    $blue  $black   $base

# Status bar

bar {
    position top
    swaybar_command waybar
}

# Moving around

bindsym {
    $mod+Left focus left
    $mod+Down focus down
    $mod+Up focus up
    $mod+Right focus right

    $mod+Shift+Left move left
    $mod+Shift+Down move down
    $mod+Shift+Up move up
    $mod+Shift+Right move right
}

# Resizing containers

bindsym $mod+r mode "Resize"

mode "Resize" {
    bindsym {
        Return mode "default"
        Escape mode "default"

        Right resize shrink width 10px
        Up resize grow height 10px
        Down resize shrink height 10px
        Left resize grow width 10px
    }
}

# Layout stuff

popup_during_fullscreen smart

bindsym {
    $mod+b splith
    $mod+v splitv
    $mod+t layout tabbed
    $mod+s layout stacking
    $mod+e layout toggle split

    $mod+f fullscreen
    $mod+a focus parent
    $mod+space focus mode_toggle
    $mod+Shift+space floating toggle
}

for_window [shell="xwayland"] title_format "[XWayland] %title"

for_window {
    [app_id="vesktop"] opacity 0.9
    [app_id="dev.zed.Zed"] opacity 0.9
    [app_id="com.ayugram.desktop"] opacity 0.9
    [instance="spotify"] move container to workspace 10, workspace 10, opacity 0.9

    [title="About*"] floating enable, move position center
    [title="about*"] floating enable, move position center
    [title="Hakkında*"] floating enable, move position center
    [title="hakkında*"] floating enable, move position center
    [title="OCR Result"] floating enable, move position center
    [title="Sound Manager"] floating enable, move position center
    [title="Network Manager"] floating enable, move position center
    [title="Bluetooth Manager"] floating enable, move position center

    [app_id="org.cachyos.hello"] floating enable, move position center
    [app_id="cute-sway-recorder"] floating enable, move position center
    [app_id="org.cachyos.cachyos-pi"] floating enable, move position center
    [app_id="org.cachyos.scx-manager"] floating enable, move position center
    [app_id="org.keepassxc.KeePassXC"] floating enable, move position center
    [app_id="org.cachyos.KernelManager"] floating enable, move position center
    [app_id="io.github.quodlibet.QuodLibet"] floating enable, move position center

    [app_id="7zFM"] floating enable, move position center, opacity 0.9
    [app_id="pcmanfm"] floating enable, move position center, opacity 0.9
    [app_id="xarchiver"] floating enable, move position center, opacity 0.9
    [app_id="pavucontrol"] floating enable, move position center, opacity 0.9
    [app_id="nm-applet"] floating enable, move position center, opacity 0.9
    [app_id="nm-connection-*"] floating enable, move position center, opacity 0.9
}

# Workspaces

bindsym {
    Tab+Left workspace prev
    Tab+Right workspace next

    $mod+1 workspace number 1
    $mod+2 workspace number 2
    $mod+3 workspace number 3
    $mod+4 workspace number 4
    $mod+5 workspace number 5
    $mod+6 workspace number 6
    $mod+7 workspace number 7
    $mod+8 workspace number 8
    $mod+9 workspace number 9
    $mod+0 workspace number 10

    $mod+Shift+1 move container to workspace number 1
    $mod+Shift+2 move container to workspace number 2
    $mod+Shift+3 move container to workspace number 3
    $mod+Shift+4 move container to workspace number 4
    $mod+Shift+5 move container to workspace number 5
    $mod+Shift+6 move container to workspace number 6
    $mod+Shift+7 move container to workspace number 7
    $mod+Shift+8 move container to workspace number 8
    $mod+Shift+9 move container to workspace number 9
    $mod+Shift+0 move container to workspace number 10
}

# Scratchpad

bindsym {
    $mod+minus scratchpad show
    $mod+Shift+minus move scratchpad
}

# Shortcuts

floating_modifier $mod normal

bindsym {
	# Window actions
    $mod+q kill
    $mod+Shift+r reload

    # Tool keybinds
    $mod+Return exec $terminal
    $mod+i exec $file-manager
    $mod+w exec $web-browser
    $mod+z exec $screen-magnifier
    $mod+o exec $screen-ocr
    $mod+p exec $color-picker
    $mod+m exec $application-menu
    $mod+c exec $clipboard-menu
    $mod+Shift+c exec cliphist wipe # Clipboard clear

    # Suprise
    XF86Calculator exec xdg-open "https://www.youtube.com/watch?v=dQw4w9WgXcQ"

    # Backlight Control
    XF86MonBrightnessUp exec brightnessctl set +1% | grep -oP '\(\K[^%]+' > $XDG_RUNTIME_DIR/wob.sock
    XF86MonBrightnessDown exec brightnessctl set 1%- | grep -oP '\(\K[^%]+' > $XDG_RUNTIME_DIR/wob.sock

    # Sound Control
    XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- \
        && wpctl get-volume @DEFAULT_AUDIO_SINK@ \
        | awk '{print $2*100}' > $XDG_RUNTIME_DIR/wob.sock
    XF86AudioRaiseVolume exec wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 1%+ \
        && wpctl get-volume @DEFAULT_AUDIO_SINK@ \
        | awk '{print $2*100}' > $XDG_RUNTIME_DIR/wob.sock

    # Screenshot
    Shift+Print exec grimshot copy output \
        && notify-send -i edit-copy "Screenshot" "Full screen copied to clipboard"
    Shift+Alt+Print exec grimshot copy active \
        && notify-send -i edit-copy "Screenshot" "Active window copied to clipboard"
    Shift+Control+Print exec grimshot copy area \
        && notify-send -i edit-copy "Screenshot" "Selected area copied to clipboard"
    Print exec grimshot save output $XDG_SCREENSHOTS_DIR/$(date +"%Y%m%d-%H%M%S").png \
        && notify-send "Screenshot" "Full screen saved to folder"
    Alt+Print exec grimshot save active $XDG_SCREENSHOTS_DIR/$(date +"%Y%m%d-%H%M%S").png \
        && notify-send "Screenshot" "Active window saved to folder"
    Control+Print exec grimshot save area $XDG_SCREENSHOTS_DIR/$(date +"%Y%m%d-%H%M%S").png \
        && notify-send "Screenshot" "Selected area saved to folder"
}

# Idle manager

set $screenlock grim /tmp/screenshot.png \
    && ffmpeg -i /tmp/screenshot.png -vf "gblur=sigma=2" -frames:v 1 -y /tmp/lock-image.png \
    && swaylock -f -i /tmp/lock-image.png

bindsym XF86Launch2 exec bash -c "$screenlock"
exec swayidle -w before-sleep 'swaylock -f -c 000000'

# exec swayidle -w \
#    timeout 300 '$screenlock' \
#    timeout 600 'swaymsg "output * power off"' \
#    resume 'swaymsg "output * power on"'

# Power menu

bindsym $mod+Shift+e exec swaynag -t default -m "Power Menu" \
    -b "Poweroff" "systemctl poweroff" \
    -b "Reboot" "systemctl reboot" \
    -b "Suspend" "systemctl suspend" \
    -b "Exit" "swaymsg exit" \
    -b "Lock" "bash -c '$screenlock'"

# Auto start

seat * xcursor_theme ComixCursors-Slim-Black 20

exec_always {
    # Theme
    gsettings set org.gnome.desktop.interface font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface document-font-name "Iosevka 10"
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"
    gsettings set org.gnome.desktop.wm.preferences theme "Adwaita"
    gsettings set org.gnome.desktop.interface icon-theme "Adwaita"
    gsettings set org.gnome.desktop.interface cursor-theme "ComixCursors-Slim-Black"
    gsettings set org.gnome.desktop.interface cursor-size 20
}

exec {
	# Environments
    dbus-update-activation-environment --systemd \
        DISPLAY \
        WAYLAND_DISPLAY \
        XDG_CURRENT_DESKTOP \
        XDG_SESSION_TYPE \
        XDG_SESSION_DESKTOP \
        GTK_THEME \
        XCURSOR_SIZE \
        XCURSOR_THEME \
        SWAYSOCK \
        I3SOCK

    # Notification daemon
	mako
    rm -f $XDG_RUNTIME_DIR/wob.sock \
        && mkfifo $XDG_RUNTIME_DIR/wob.sock \
        && tail -f $XDG_RUNTIME_DIR/wob.sock | wob

	# Clipboard manager daemon
	wl-paste --type text --watch cliphist store
	wl-paste --type image --watch cliphist store

	# Gamma manager daemon
	wlsunset -S 06:30 -s 19:30 -t 4000 -T 6500

    # KDE Connect daemon
	kdeconnectd
}

